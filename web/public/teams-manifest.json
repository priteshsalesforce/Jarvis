{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "00000000-0000-0000-0000-000000000000",
  "packageName": "com.salesforce.jarvis",
  "developer": {
    "name": "Salesforce",
    "websiteUrl": "https://www.salesforce.com",
    "privacyUrl": "https://www.salesforce.com/company/privacy/",
    "termsOfUseUrl": "https://www.salesforce.com/company/legal/"
  },
  "name": {
    "short": "Jarvis",
    "full": "Jarvis — your personal assistant at work"
  },
  "description": {
    "short": "Your personal assistant at work — briefs, reminders and routine admin.",
    "full": "Jarvis quietly handles the small stuff — emails, prep, PTO and training reminders — so you can focus on the rest. It asks before doing anything bigger, and every action is reversible."
  },
  "icons": {
    "color": "jarvis-icon.png",
    "outline": "jarvis-icon-transparent.png"
  },
  "accentColor": "#5C2E91",
  "staticTabs": [
    {
      "entityId": "today",
      "name": "Today",
      "contentUrl": "https://jarvis.example.com/?tab=today",
      "scopes": ["personal"]
    },
    {
      "entityId": "conversations",
      "name": "Conversations",
      "contentUrl": "https://jarvis.example.com/?tab=conversations",
      "scopes": ["personal"]
    },
    {
      "entityId": "feed",
      "name": "Feed",
      "contentUrl": "https://jarvis.example.com/?tab=feed",
      "scopes": ["personal"]
    },
    {
      "entityId": "skills",
      "name": "Skills",
      "contentUrl": "https://jarvis.example.com/?tab=skills",
      "scopes": ["personal"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["jarvis.example.com"]
}
